# ============================================================
# Kiwii Brand Research Hub · 后端环境变量
# 复制本文件为 .env 后填入真实 Key
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS / Linux)
# .env 已在 .gitignore 中，不会被提交
# ============================================================

# ---- LLM 提供商 ----
# 方案 A：MiniMax M3 走第三方平台（数眼智能 shuyanai.com）
#   注册：https://platform.shuyanai.com
#   文档：https://blog.csdn.net/2501_94459390/article/details/161614109
MINIMAX_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://platform.shuyanai.com/v1
MINIMAX_MODEL=MiniMax-M3

# 方案 B（备选）：如果以后想换 DeepSeek / OpenAI / 硅基流动，改下面这行即可
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ---- Web 服务 ----
PORT=8000
HOST=0.0.0.0
