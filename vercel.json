{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "server.mjs": {
      "includeFiles": "{*.html,assets/**,_shared/**,brands/**}"
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
